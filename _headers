# JSON data files: never cache at CDN, always fetch from origin
/data/*
  Cache-Control: public, max-age=0, s-maxage=0, must-revalidate
  CDN-Cache-Control: no-store

# HTML pages: no CDN cache
/*.html
  Cache-Control: public, max-age=0, s-maxage=0, must-revalidate
  CDN-Cache-Control: no-store

/src/pages/*.html
  Cache-Control: public, max-age=0, s-maxage=0, must-revalidate
  CDN-Cache-Control: no-store

# CSS/JS: 1 hour CDN cache
/src/css/*.css
  Cache-Control: public, max-age=3600, s-maxage=3600

/src/js/*.js
  Cache-Control: public, max-age=3600, s-maxage=3600
